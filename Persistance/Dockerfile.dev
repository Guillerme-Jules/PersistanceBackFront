FROM dunglas/frankenphp:1-php8.4

# Extensions PHP nécessaires à Symfony + PostgreSQL
RUN install-php-extensions intl pdo_pgsql zip opcache

# Composer
COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

RUN printf "opcache.validate_timestamps=0\nopcache.memory_consumption=256\nopcache.max_accelerated_files=30000\nopcache.interned_strings_buffer=24\nrealpath_cache_size=4096K\nrealpath_cache_ttl=600\n" \
    > "$PHP_INI_DIR/conf.d/zz-perf.ini"

WORKDIR /app

# Installe les dépendances au premier démarrage, puis lance le serveur
CMD sh -c "[ -d vendor ] || composer install --no-interaction; \
           exec frankenphp run --config /etc/caddy/Caddyfile"
